# ─────────────────────────────────────────────────────────────
# Podcast Outreach — Environment Variables
# Copy this file to .env and fill in all values before running.
# ─────────────────────────────────────────────────────────────

# ── Supabase PostgreSQL (direct connection) ────────────────────
# From Supabase dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# ── Anthropic API ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail API ─────────────────────────────────────────────────
GMAIL_CREDENTIALS_FILE=gmail_credentials.json
GMAIL_TOKEN_FILE=gmail_token.json
GMAIL_FROM=your-email@gmail.com

# ── Enrichment Settings ───────────────────────────────────────
MAX_CONCURRENT_REQUESTS=5
SCRAPING_DELAY_MS=500

# ── Lead Scoring ──────────────────────────────────────────────
MIN_EPISODE_COUNT=10
PRIORITY_CATEGORIES=business,entrepreneurship,technology,marketing,self-improvement
