# ─────────────────────────────────────────────────────────────
# Podcast Pipeline — Environment Variables
# Copy this file to .env and fill in all values before running.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3000
# Public base URL (no trailing slash) — used for dashboard links and OAuth redirects
BASE_URL=https://your-app.railway.app

# ── Supabase ──────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Service Role key (NOT the anon key) — has full DB access
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic ─────────────────────────────────────────────────
# API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Listen Notes ──────────────────────────────────────────────
# API key from https://www.listennotes.com/api/
LISTENNOTES_API_KEY=

# ── Google Custom Search ──────────────────────────────────────
# Create a Programmable Search Engine at https://cse.google.com
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# ── Google OAuth (Gmail API) ──────────────────────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com
# Add GOOGLE_REDIRECT_URI to the authorised redirect URIs list
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/gmail/callback

# ── Resend (transactional email) ──────────────────────────────
# API key from https://resend.com
RESEND_API_KEY=re_...
# Verified sender address in your Resend account
RESEND_FROM_EMAIL=pipeline@yourdomain.com
